# Local development
DATABASE_URL="file:./prisma/dev.db"

# Site URL - used for SEO, Open Graph, canonical URLs
# Local: http://localhost:3000 (default when not set)
# Production: https://aphbay.com
# NEXT_PUBLIC_SITE_URL=https://aphbay.com

# Ollama Cloud - for "Generate blog post content" in admin entry editor
# Get API key at https://ollama.com/settings/keys
# OLLAMA_API_KEY=your_key_here
# OLLAMA_MODEL=gemini-3-flash-preview:cloud
