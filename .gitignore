# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env
.env.*
!.env.example

# production data (SQLite DB on server)
/data/

# local scrape URL lists (large, not needed in repo)
scripts/liteapks-urls.txt
scripts/modyolo-urls.txt

# scraped images (long paths on Windows; persisted on VPS via docker bind mount)
public/images/

# local SQLite database
prisma/dev.db
prisma/dev.db-journal

# scrape artifacts / binaries
scripts/downloaded_apks/
scripts/*.csv
scripts/*.xlsx
scripts/*.xml
scripts/debug-page.html
scripts/download-test-output.txt
scripts/links.txt

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

/app/generated/prisma
